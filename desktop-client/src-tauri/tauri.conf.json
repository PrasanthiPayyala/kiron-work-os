{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Kiron Presence",
  "version": "0.1.0",
  "identifier": "in.innomaxsol.kiron.presence",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "signin",
        "title": "Kiron Presence — Sign in",
        "width": 420,
        "height": 520,
        "minWidth": 360,
        "minHeight": 460,
        "resizable": false,
        "center": true,
        "decorations": true,
        "visible": true,
        "focus": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://crm.innomaxsol.com http://localhost:8787"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg"],
    "publisher": "Innomax Solutions",
    "shortDescription": "Presence tracker for Kiron Work OS",
    "longDescription": "Auto check-in on unlock, auto check-out on shutdown, activity heartbeats to Kiron Work OS. Presence only — no screenshots, no keystrokes, no app names, no URLs.",
    "category": "Productivity",
    "copyright": "© 2026 Innomax Solutions",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "signCommand": {
        "cmd": "signtool.exe",
        "args": [
          "sign",
          "/fd", "SHA256",
          "/tr", "http://timestamp.digicert.com",
          "/td", "SHA256",
          "/f", "%KIRON_CODE_SIGN_CERT%",
          "/p", "%KIRON_CODE_SIGN_PASSWORD%",
          "%1"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "Developer ID Application: Innomax Solutions",
      "hardenedRuntime": true,
      "entitlements": null
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://crm.innomaxsol.com/desktop/latest.json"
      ],
      "dialog": false,
      "pubkey": "REPLACE_WITH_ED25519_PUBKEY_FROM_TAURI_SIGNER_GENERATE",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
