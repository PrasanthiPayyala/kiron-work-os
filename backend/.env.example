# Copy to backend/.env and fill in. The POSTGRES password is the one set when
# PostgreSQL was installed (local dev) or your VPS Postgres password.
DATABASE_URL=postgresql+psycopg://postgres:CHANGEME@localhost:5432/kiron

# JWT signing — generate a long random string for production.
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=14

# CORS — the Vite dev server origin(s), comma-separated.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
