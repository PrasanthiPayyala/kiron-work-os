# Production backend environment for the Kiron API.
# Copy to the VM as /etc/kiron/backend.env and fill in the real values.
# NEVER commit the filled-in version — it holds the DB password + JWT secret.

# Postgres on the same VM. Create the role/db per DEPLOY.md, then set the
# password you chose here. Port 5432 is the default system Postgres port.
DATABASE_URL=postgresql+psycopg://kiron:CHANGE_ME_DB_PASSWORD@localhost:5432/kiron

# Generate with:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_64_CHAR_RANDOM_HEX_STRING

# Access tokens are short-lived; refresh tokens last days. Tune as needed.
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=14

# With nginx serving the PWA and proxying /api on the SAME origin, CORS is not
# strictly required. Keep your real domain here as defense-in-depth (and in
# case anything hits the API cross-origin). Comma-separated, no trailing slash.
CORS_ORIGINS=https://kiron.example.com

# Where the files router writes uploaded bytes. Pre-create on the VM:
#   sudo mkdir -p /var/lib/kiron/files
#   sudo chown kiron:kiron /var/lib/kiron/files
FILES_DIR=/var/lib/kiron/files

# Public origin of the PWA — used to build the password reset link in emails.
APP_BASE_URL=https://kiron.example.com

# Outgoing SMTP — password reset AND leave / attendance-permission /
# comp-off notification emails to HR + applicants.
# Sender mailbox: noreply@innomaxsol.com is the default — create that account
# in cPanel and put its credentials here. Kiron Group cPanel mail typically:
#   SMTP_HOST=mail.innomaxsol.com
#   SMTP_PORT=465
#   SMTP_SSL=true
#   SMTP_USERNAME=noreply@innomaxsol.com
#   SMTP_PASSWORD=<from cPanel>
# Emails go out via one shared sender + spoofed From-display-name + a
# Reply-To header pointing at the actual counterpart (applicant on HR
# emails, decider on applicant emails) — so "Reply" in Gmail lands in
# the right inbox without collecting per-employee credentials.
# If SMTP_HOST is left blank, the backend logs the message to stdout
# instead of trying to send (useful while DNS / cPanel are still being wired).
SMTP_HOST=
SMTP_PORT=465
SMTP_SSL=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Kiron Work OS <noreply@innomaxsol.com>

# Reset tokens expire after this many minutes (single-use, hashed in DB).
PASSWORD_RESET_TTL_MIN=60

# SLA breach scheduler runs inside the FastAPI process and uses a Postgres
# advisory lock so it's safe even with `uvicorn --workers > 1`. Disable in
# environments where you'd rather drive the check via cron.
SLA_CHECK_ENABLED=true
SLA_CHECK_INTERVAL_MIN=15
SLA_WARN_WINDOW_HOURS=4
